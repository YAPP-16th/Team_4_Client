<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="75dp"
    android:paddingVertical="15dp"
    android:paddingHorizontal="25dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/schedule_item_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="123"
        android:textSize="14sp"
        android:fontFamily="@font/sf_pro_bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/schedule_item_gametype"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="123"
        android:textSize="12sp"
        android:layout_marginTop="13dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/schedule_item_title"/>

    <View
        android:layout_width="1dp"
        android:layout_height="12sp"
        android:background="@color/colorWarmGrey"
        android:layout_marginLeft="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/schedule_item_gametype"
        app:layout_constraintStart_toEndOf="@+id/schedule_item_gametype"
        app:layout_constraintTop_toTopOf="@+id/schedule_item_gametype" />

    <TextView
        android:id="@+id/schedule_item_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="123"
        android:textSize="12sp"
        android:layout_marginLeft="16dp"
        app:layout_constraintBottom_toBottomOf="@+id/schedule_item_gametype"
        app:layout_constraintStart_toEndOf="@+id/schedule_item_gametype"
        app:layout_constraintTop_toTopOf="@+id/schedule_item_gametype"/>

    <TextView
        android:id="@+id/schedule_item_gameday"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="123"
        android:textSize="14sp"
        android:fontFamily="@font/sf_pro_bold"
        android:layout_marginTop="5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/schedule_item_gametime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="123"
        android:textSize="12sp"
        android:layout_marginTop="5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/schedule_item_gameday"
        app:layout_constraintBottom_toBottomOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>